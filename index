    <div class="callout"><strong>Goal:</strong> Expand beyond PT. The operating system concept works for any small healthcare practice. Grow the feature set, the market, and the moat.</div>
    <div class="timeline">
      <div class="tl-item"><div class="tl-phase">Year 2 Q1</div><div class="tl-title">EMR & Scheduling Integrations</div><div class="tl-desc">Connect to Jane, Prompt, WebPT, and other PT EMRs. Auto-trigger SOP reviews when processes change. Import patient volume data for workload-aware SOPs.</div></div>
      <div class="tl-item"><div class="tl-phase">Year 2 Q2</div><div class="tl-title">Mobile Companion App</div><div class="tl-desc">Staff can pull up SOPs and ask the AI questions from their phone on the clinic floor. Push notifications for stale SOPs and approval requests.</div></div>
      <div class="tl-item"><div class="tl-phase">Year 2 Q3</div><div class="tl-title">Industry Expansion</div><div class="tl-desc">Adapt the platform for OT, speech therapy, chiropractic, and dental. The core engine is the same — only the SOP templates and role blueprints change. Each vertical multiplies the addressable market.</div></div>
      <div class="tl-item"><div class="tl-phase">Year 2 Q4</div><div class="tl-title">Analytics & Insights</div><div class="tl-desc">Dashboard showing: SOP coverage by role, knowledge risk score, onboarding efficiency trends, most-queried topics (identifies training gaps), cross-clinic benchmarks for multi-location subscribers.</div></div>
      <div class="tl-item"><div class="tl-phase">Year 3+</div><div class="tl-title">The Platform Play</div><div class="tl-desc">Open marketplace for SOP templates (clinics can share anonymized best practices). Industry benchmarking. Consulting marketplace where certified partners help clinics set up their systems. Conference presence. The goal: when any small healthcare practice thinks "operations," they think of this product.</div></div>
    </div>
  `},
];

document.getElementById('phaseTabs').innerHTML = PHASES.map((p, i) =>
  `<button class="phase-tab${i === 0 ? ' active' : ''}" onclick="showPhase('${p.id}',this)" style="--pc:${p.color}">${p.label}</button>`
).join('');
document.getElementById('phaseContent').innerHTML = PHASES.map((p, i) =>
  `<div class="phase-content${i === 0 ? ' active' : ''}" id="${p.id}">${p.content}</div>`
).join('');

function showPhase(id, el) {
  document.querySelectorAll('.phase-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.phase-content').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById(id).classList.add('active');
}

// ═══ NOTION DATABASES ═══
const NOTION_DBS = [
  { icon: '📋', name: 'SOPs', desc: 'The core database. Every procedure, policy, and process. Structured with 11 properties (see SOP Engine section). Templates for each SOP category.', status: 'Core' },
  { icon: '👤', name: 'Role Blueprints', desc: 'One entry per role. Properties: Role Name, Department, Reports To, Responsibilities (rich text), Associated SOPs (relation to SOP database), Training Sequence (ordered checklist), Key Contacts, Escalation Path. This is what a new hire sees on day one.', status: 'Core' },
  { icon: '📝', name: 'Meeting Notes', desc: 'Captured in real-time or after the fact. Properties: Date, Attendees, Topic, Notes (rich text), Action Items (checklist), SOPs Generated (relation). The AI reads these to draft SOPs.', status: 'Core' },
  { icon: '⚖️', name: 'Decision Log', desc: 'Every significant business decision, recorded once and retrievable forever. Properties: Decision, Date, Made By, Rationale, Alternatives Considered, Related SOPs. When staff ask "why do we do it this way?" the AI pulls from here.', status: 'Core' },
  { icon: '📬', name: 'Approval Queue', desc: 'Change requests waiting for Owner Key approval. Properties: Requested By, SOP (relation), Change Description, Priority, Status (Pending/Approved/Rejected), Owner Notes. The Owner reviews and approves from this single view.', status: 'Security' },
  { icon: '📜', name: 'Audit Trail', desc: 'Auto-logged entries for every meaningful action. Properties: Timestamp, User, Action (Created/Modified/Published/Archived), Target SOP (relation), Details. Never edited, never deleted. Append-only.', status: 'Security' },
  { icon: '🏢', name: 'Vendor Directory', desc: 'Every vendor, tool, and service the clinic uses. Properties: Name, Category, Contact, Login Info (secured), Contract Renewal Date, BAA Status, Monthly Cost, Notes. Eliminates "who do we call about X?"', status: 'Knowledge' },
  { icon: '📖', name: 'Policy Library', desc: 'Higher-level policies that SOPs implement. Properties: Policy Name, Category, Effective Date, Review Cycle, Full Text. Links to related SOPs. Think of policies as the "why" and SOPs as the "how."', status: 'Knowledge' },
];

document.getElementById('notionDatabases').innerHTML = NOTION_DBS.map(db =>
  `<div class="card"><div class="card-h">${db.icon} ${db.name} <span class="card-tag" style="background:${db.status === 'Core' ? 'var(--blue-bg)' : db.status === 'Security' ? 'var(--red-bg)' : 'var(--green-bg)'};color:${db.status === 'Core' ? 'var(--blue)' : db.status === 'Security' ? 'var(--red)' : 'var(--green)'};border:1px solid ${db.status === 'Core' ? 'var(--blue-border)' : db.status === 'Security' ? 'var(--red-border)' : 'var(--green-border)'};margin:0 0 0 8px">${db.status}</span></div><div class="card-p">${db.desc}</div></div>`
).join('');

// ═══ SCROLL SPY ═══
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const id = entry.target.id;
      document.querySelectorAll('.nav-btn').forEach(b => {
        b.classList.toggle('active', b.onclick.toString().includes(id));
      });
    }
  });
}, { threshold: 0.2, rootMargin: '-52px 0px -60% 0px' });
SECTIONS.forEach(s => { const el = document.getElementById(s.id); if (el) observer.observe(el); });
</script>
